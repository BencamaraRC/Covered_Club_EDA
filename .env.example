# Nomis API key — only needed if running Census v2 module
# Get one free at https://www.nomisweb.co.uk/
NOMIS_API_KEY=

# ONS Beta API — no key required, override here if needed
ONS_API_BASE=https://api.beta.ons.gov.uk/v1

# Anthropic API key — required for the "Ask the Analyst" AI chat feature
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=
